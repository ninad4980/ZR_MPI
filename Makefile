# =========================================================
# Compiler
# =========================================================

CXX = mpic++
# =========================================================
# Flags
# =========================================================
CXXFLAGS  := -O3 -std=c++20 -fopenmp
CPPFLAGS  := 

# include directories
INCLUDES  := -I.

# libraries
LDFLAGS := 
LDLIBS    :=
# Directories
# =========================================================
OBJDIR    := obj
SRCDIR    := .
TARGET    := plasma

# =========================================================
# Sources
# =========================================================
SRC       := $(wildcard $(SRCDIR)/*.cpp)

OBJS      := $(patsubst $(SRCDIR)/%.cpp,$(OBJDIR)/%.o,$(SRC))

DEPS      := $(OBJS:.o=.d)

# =========================================================
# Default target
# =========================================================
all: $(TARGET)

#all:  $(target) build
# =========================================================
# Link
# =========================================================
$(TARGET): $(OBJS)
	$(CXX) $(CXXFLAGS) $(LDFLAGS) -o $@ $^ $(LDLIBS)
# =========================================================
# Compile
# =========================================================
$(OBJDIR)/%.o: $(SRCDIR)/%.cpp | $(OBJDIR)
	$(CXX) $(CXXFLAGS) $(CPPFLAGS) $(INCLUDES) -c $< -o $@

#%.o: %.cpp
## =========================================================
# Object directory
# =========================================================
$(OBJDIR):
	mkdir -p $(OBJDIR)

#build:
#	@mkdir -p $(OBJDIR)
#	mv *.o  $(OBJDIR)

# =========================================================
# Clean
# =========================================================
clean:
	rm -rf $(OBJDIR) $(TARGET)
	rm -rf results/*

cleanresults:
	rm -rf results/*

# =========================================================
# Include dependency files
# =========================================================
-include $(DEPS)


